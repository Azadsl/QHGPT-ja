    <audio id="muyuSound" src="muyu.mp3"></audio>
    <audio id="qingSound" src="qing.mp3"></audio>
    <audio id="fenglingSound" src="fengling.mp3"></audio>
    <audio id="zhongSound" src="zhong.mp3"></audio>
    <script>
        const muyu = document.querySelector('.muyu');
        const qing = document.querySelector('.qing');
        const fengling = document.querySelector('.fengling');
        const zhong = document.querySelector('.zhong');
        const gongdeContainer = document.getElementById('gongdeContainer');
        let muyuAudio = document.getElementById('muyuSound');
        let qingAudio = document.getElementById('qingSound');
        let fenglingAudio = document.getElementById('fenglingSound');
        let zhongAudio = document.getElementById('zhongSound');
        // 修复iOS等设备需要用户交互后才能播放的问题
        let isAudioReady = false;
        function initAudio() {
            // 重新创建音频对象确保可以循环播放
            muyuAudio = new Audio('muyu.mp3');
            qingAudio = new Audio('qing.mp3');
            fenglingAudio = new Audio('fengling.mp3');
            zhongAudio = new Audio('zhong.mp3');
            muyuAudio.load();
            qingAudio.load();
            fenglingAudio.load();
            zhongAudio.load();
            isAudioReady = true;
        }
        function playMuyuSound() {
            if (!isAudioReady) {
                initAudio();
            }
            try {
                // 重置播放进度
                muyuAudio.currentTime = 0;
                muyuAudio.play();
            } catch (e) {
                console.log('音频播放失败，请检查浏览器设置');
            }
        }
        function playQingSound() {
            if (!isAudioReady) {
                initAudio();
            }
            try {
                // 重置播放进度
                qingAudio.currentTime = 0;
                qingAudio.play();
            } catch (e) {
                console.log('音频播放失败，请检查浏览器设置');
            }
        }
        function playFenglingSound() {
            if (!isAudioReady) {
                initAudio();
            }
            try {
                // 重置播放进度
                fenglingAudio.currentTime = 0;
                fenglingAudio.play();
            } catch (e) {
                console.log('音频播放失败，请检查浏览器设置');
            }
        }
        function playZhongSound() {
            if (!isAudioReady) {
                initAudio();
            }
            try {
                // 重置播放进度
                zhongAudio.currentTime = 0;
                zhongAudio.play();
            } catch (e) {
                console.log('音频播放失败，请检查浏览器设置');
            }
        }
        // 木鱼点击处理函数
        function handleMuyuKnock() {
            muyu.style.transform = 'scale(0.95)';
            setTimeout(() => {
                muyu.style.transform = 'scale(1)';
            }, 100);
            playMuyuSound();
        }
        // 磬点击处理函数
        function handleQingKnock() {
            qing.style.transform = 'scale(0.95)';
            setTimeout(() => {
                qing.style.transform = 'scale(1)';
            }, 100);
            playQingSound();
        }
        // 风铃点击处理函数
        function handleFenglingKnock() {
            fengling.style.transform = 'scale(0.95)';
            setTimeout(() => {
                fengling.style.transform = 'scale(1)';
            }, 100);
            playFenglingSound();
        }
        // 钟点击处理函数
        function handleZhongKnock() {
            zhong.style.transform = 'scale(0.95)';
            setTimeout(() => {
                zhong.style.transform = 'scale(1)';
            }, 100);
            playZhongSound();
        }
        // 木鱼事件监听
        muyu.addEventListener('click', handleMuyuKnock);
        muyu.addEventListener('touchstart', (e) => {
            e.preventDefault();
            handleMuyuKnock();
        });
        // 磬事件监听
        qing.addEventListener('click', handleQingKnock);
        qing.addEventListener('touchstart', (e) => {
            e.preventDefault();
            handleQingKnock();
        });
        // 风铃事件监听
        fengling.addEventListener('click', handleFenglingKnock);
        fengling.addEventListener('touchstart', (e) => {
            e.preventDefault();
            handleFenglingKnock();
        });
        // 钟事件监听
        zhong.addEventListener('click', handleZhongKnock);
        zhong.addEventListener('touchstart', (e) => {
            e.preventDefault();
            handleZhongKnock();
        });
        // 首次触摸事件初始化音频
        document.addEventListener('touchstart', initAudio, { once: true });
        document.addEventListener('click', initAudio, { once: true });
    </script>
