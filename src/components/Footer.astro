<script>
    // 獲取元素
    var sangShangTrigger = document.querySelector('.sang_shang_trigger');
    var modal = document.getElementById('sangShangModal');
    var closeButton = document.querySelector('.close_button');

    // 檢查元素是否存在，避免報錯
    if (sangShangTrigger && modal && closeButton) {
         // 當點擊觸發區域時，顯示模態框
        sangShangTrigger.onclick = function() {
            modal.style.display = "flex"; // 使用 flex 來居中模態框內容
        }

        // 當點擊關閉按鈕時，隱藏模態框
        closeButton.onclick = function() {
            modal.style.display = "none";
        }

        // 當用戶點擊模態框背景（而不是內容區域）時，隱藏模態框
        window.onclick = function(event) {
            if (event.target == modal) {
                modal.style.display = "none";
            }
        }

        // 當用戶按下 Esc 鍵時，隱藏模態框
        document.addEventListener('keydown', function(event) {
            if (event.key === "Escape" || event.keyCode === 27) { // Esc key
                if (modal.style.display !== "none") {
                    modal.style.display = "none";
                }
            }
        });
    } else {
        console.error("隨喜贊賞模塊所需的元素未找到，功能可能無法正常工作。請檢查 .sang_shang_trigger, #sangShangModal, .close_button 是否存在於 HTML 中。");
    }
</script>
